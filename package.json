{
  "name": "code-smells-catalog",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/generate-og-images.mjs && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:build-output": "vitest run --config vitest.build-output.config.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "og:generate": "node scripts/generate-og-images.mjs",
    "redirects:generate": "node scripts/generate-gh-pages-redirects.mjs"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.3",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@nanostores/preact": "^1.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/mdast": "^4.0.4",
    "@vercel/analytics": "^2.0.1",
    "astro": "^5.18.0",
    "nanostores": "^1.1.1",
    "preact": "^10.29.0",
    "shiki": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "unist-util-visit": "^5.1.0",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@size-limit/file": "^12.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "gray-matter": "^4.0.3",
    "linkedom": "^0.18.12",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "satori": "^0.25.0",
    "size-limit": "^12.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
