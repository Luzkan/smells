---
/** Previous/next smell navigation. Wraps around at edges of the alphabetical list. */
import { getObstructionTheme } from '../../lib/category-colors';
import Icon from '../icons/Icon.astro';
import { ICON_ARROW_LEFT, ICON_ARROW_RIGHT } from '../../lib/icon-paths';
import type { SmellLink } from '../../lib/types';
import type { ObstructionCategory } from '../../lib/constants';

interface Props {
  prev: SmellLink;
  next: SmellLink;
  category: ObstructionCategory;
}

const { prev, next, category } = Astro.props;
const prevColor = getObstructionTheme(prev.obstruction).color;
const nextColor = getObstructionTheme(next.obstruction).color;
---

{
  (prev || next) && (
    <nav class="prev-next" aria-label="Previous and next articles">
      {category && (
        <h3 class="prev-next__heading">
          More from <a href={`/?obstruction=${encodeURIComponent(category)}`}>{category}</a>
        </h3>
      )}
      <div class="prev-next__grid">
        {prev ? (
          <a href={prev.href} class="prev-next__card" style={`--card-color: ${prevColor}`}>
            <span class="prev-next__direction">
              <Icon icon={ICON_ARROW_LEFT} size={16} />
              Previous
            </span>
            <span class="prev-next__title">{prev.title}</span>
            {prev.description && <span class="prev-next__desc">{prev.description}</span>}
            <span class="prev-next__tags">
              <span
                class="prev-next__tag"
                style={`background: color-mix(in srgb, ${prevColor} 12%, transparent); color: ${prevColor}`}
              >
                {prev.obstruction}
              </span>
              {prev.occurrence && (
                <span
                  class="prev-next__tag"
                  style="background: var(--blue-light); color: var(--blue);"
                >
                  {prev.occurrence}
                </span>
              )}
            </span>
          </a>
        ) : (
          <div />
        )}
        {next ? (
          <a
            href={next.href}
            class="prev-next__card prev-next__card--next"
            style={`--card-color: ${nextColor}`}
          >
            <span class="prev-next__direction">
              Next
              <Icon icon={ICON_ARROW_RIGHT} size={16} />
            </span>
            <span class="prev-next__title">{next.title}</span>
            {next.description && <span class="prev-next__desc">{next.description}</span>}
            <span class="prev-next__tags">
              <span
                class="prev-next__tag"
                style={`background: color-mix(in srgb, ${nextColor} 12%, transparent); color: ${nextColor}`}
              >
                {next.obstruction}
              </span>
              {next.occurrence && (
                <span
                  class="prev-next__tag"
                  style="background: var(--blue-light); color: var(--blue);"
                >
                  {next.occurrence}
                </span>
              )}
            </span>
          </a>
        ) : (
          <div />
        )}
      </div>
    </nav>
  )
}

<style>
  .prev-next {
    margin: 0 0 36px;
  }

  .prev-next__heading {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--text-secondary);
    margin: 0 0 16px;
    font-variation-settings: 'opsz' 24;
  }

  .prev-next__heading a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--duration-fast);
  }

  .prev-next__heading a:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }

  .prev-next__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  @media (max-width: 599px) {
    .prev-next__grid {
      grid-template-columns: 1fr;
    }
  }

  .prev-next__card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px 28px;
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-left: 3px solid var(--card-color, var(--accent));
    border-radius: var(--radius-lg);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.3s var(--ease-out),
      box-shadow 0.3s var(--ease-out),
      border-color 0.2s ease;
  }

  .prev-next__card::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--purple));
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  @media (hover: hover) {
    .prev-next__card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
      border-color: var(--border);
      border-left-color: var(--card-color, var(--accent));
    }

    .prev-next__card:hover::before {
      opacity: 1;
    }
  }

  .prev-next__card--next {
    text-align: right;
    align-items: flex-end;
    border-left: 1px solid var(--border-subtle);
    border-right: 3px solid var(--card-color, var(--accent));
  }

  @media (hover: hover) {
    .prev-next__card--next:hover {
      border-left-color: var(--border);
      border-right-color: var(--card-color, var(--accent));
    }
  }

  .prev-next__card--next .prev-next__tags {
    justify-content: flex-end;
  }

  .prev-next__desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prev-next__direction {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--text-tertiary);
  }

  .prev-next__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1.3;
    font-variation-settings: 'opsz' 32;
    letter-spacing: -0.015em;
  }

  .prev-next__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 4px;
  }

  .prev-next__tag {
    font-size: 10px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    letter-spacing: 0.03em;
  }
</style>
