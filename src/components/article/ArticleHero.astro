---
/** Article hero — breadcrumb, title, dimension badges, and aliases. */
import type { SmellFrontmatter } from '../../schemas/smell';
import { getObstructionTheme } from '../../lib/category-colors';
import { COPY_FEEDBACK_MS } from '../../lib/copy-code';
import DimensionTag from '../catalog/DimensionTag.astro';

interface Props {
  data: SmellFrontmatter;
  readTime: number;
  sourceCount: number;
  description: string;
}

const { data, readTime, sourceCount, description } = Astro.props;
const { meta, categories } = data;

const formattedDate = new Date(meta.last_update_date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const obstructionColor = getObstructionTheme(categories.obstruction[0]).color;
---

<div class="article-hero" style={`--hero-tint: ${obstructionColor}`}>
  {/* Breadcrumb */}
  <nav class="article-hero__breadcrumb" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Catalog</a></li>
      <li aria-hidden="true" class="article-hero__breadcrumb-sep">&rsaquo;</li>
      <li>
        <a
          class="article-hero__breadcrumb-category"
          style={`--breadcrumb-category-color: ${obstructionColor}`}
          href={`/#obstruction=${encodeURIComponent(categories.obstruction[0])}`}
        >
          {categories.obstruction[0]}
        </a>
      </li>
      <li aria-hidden="true" class="article-hero__breadcrumb-sep">&rsaquo;</li>
      <li aria-current="page">{meta.title}</li>
    </ol>
  </nav>

  <h1 class="article-hero__title">{meta.title}</h1>

  {
    meta.known_as.length > 0 && (
      <p class="article-hero__known-as">Also known as: {meta.known_as.join(', ')}</p>
    )
  }

  {/* Tags before description — matches mockup order */}
  <div class="article-hero__tags">
    <DimensionTag
      dimensionKey="obstruction"
      value={categories.obstruction[0]}
      variant="link"
      class="article-hero__tag"
    />
    {
      categories.occurrence.map((occ) => (
        <DimensionTag
          dimensionKey="occurrence"
          value={occ}
          variant="link"
          class="article-hero__tag"
        />
      ))
    }
    {
      categories.smell_hierarchies.map((hier) => (
        <DimensionTag
          dimensionKey="smell_hierarchies"
          value={hier}
          variant="link"
          class="article-hero__tag"
        />
      ))
    }
    <DimensionTag
      dimensionKey="expanse"
      value={categories.expanse}
      label={`${categories.expanse} Class`}
      variant="link"
      class="article-hero__tag"
    />
  </div>

  {description && <p class="article-hero__desc">{description}</p>}

  {/* Meta bar with dividers */}
  <div class="article-hero__meta">
    <span class="article-hero__meta-item">
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
      {readTime} min read
    </span>
    <span class="article-hero__meta-divider" aria-hidden="true"></span>
    <span class="article-hero__meta-item">
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
      <time datetime={meta.last_update_date.toISOString().split('T')[0]}>
        {formattedDate}
      </time>
    </span>
    {
      sourceCount > 0 && (
        <Fragment>
          <span class="article-hero__meta-divider" aria-hidden="true" />
          <span class="article-hero__meta-item">
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
            {sourceCount} {sourceCount === 1 ? 'source' : 'sources'}
          </span>
        </Fragment>
      )
    }
    <span class="article-hero__meta-divider" aria-hidden="true"></span>
    <button
      class="article-hero__copy-link"
      id="copy-link-btn"
      type="button"
      aria-label="Copy link to clipboard"
      data-slug={data.slug}
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
      </svg>
      <span id="copy-link-text">Copy link</span>
    </button>
  </div>
</div>

<script is:inline define:vars={{ COPY_FEEDBACK_MS }}>
  (function () {
    const btn = document.getElementById('copy-link-btn');
    const text = document.getElementById('copy-link-text');
    if (!btn || !text) return;
    function doCopy() {
      navigator.clipboard
        .writeText(window.location.href)
        .then(function () {
          text.textContent = 'Copied!';
          btn.classList.add('article-hero__copy-link--copied');
          const slug = btn.getAttribute('data-slug');
          if (slug) {
            document.dispatchEvent(
              new CustomEvent('analytics', {
                detail: { name: 'copy_link', params: { smell: slug } },
              }),
            );
          }
          setTimeout(function () {
            text.textContent = 'Copy link';
            btn.classList.remove('article-hero__copy-link--copied');
          }, COPY_FEEDBACK_MS);
        })
        .catch(function (error) {
          console.error('[article-hero] clipboard write failed', error);
        });
    }
    btn.addEventListener('click', doCopy);
  })();
</script>

<style>
  .article-hero {
    padding-bottom: clamp(32px, 4vw, 48px);
  }

  /* Breadcrumb */
  .article-hero__breadcrumb ol {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    letter-spacing: 0.01em;
    animation: heroBlurIn 0.7s var(--ease-out) 0.05s both;
  }

  .article-hero__breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .article-hero__breadcrumb a:hover {
    color: var(--accent);
  }

  .article-hero__breadcrumb-category {
    color: var(--breadcrumb-category-color, var(--accent)) !important;
    font-weight: 600;
  }

  .article-hero__breadcrumb-sep {
    color: var(--border);
    font-size: 1.1em;
  }

  .article-hero__breadcrumb [aria-current='page'] {
    color: var(--text-primary);
    font-weight: 500;
  }

  /* Title */
  .article-hero__title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0 0 12px;
    text-wrap: balance;
    font-variation-settings: 'opsz' 72;
    animation: heroBlurIn 0.8s var(--ease-out) 0.15s both;
  }

  /* Known-as aliases */
  .article-hero__known-as {
    font-size: var(--text-lg);
    color: var(--text-tertiary);
    font-style: italic;
    letter-spacing: 0.01em;
    margin: 0 0 24px;
    animation: heroBlurIn 0.8s var(--ease-out) 0.25s both;
  }

  /* Tags */
  .article-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
    animation: heroBlurIn 0.8s var(--ease-out) 0.35s both;
  }

  :global(.article-hero__tag) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--dim-color);
    background: var(--dim-light);
    border: none;
    line-height: 1.4;
    text-decoration: none;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-smooth);
  }

  :global(.article-hero__tag:hover) {
    filter: brightness(0.88);
    transform: translateY(-1px);
  }

  /* Bar indicator is rendered by DimensionTag (.dim-tag-bar) */

  /* Description */
  .article-hero__desc {
    font-size: var(--text-lg);
    line-height: 1.8;
    max-width: 64ch;
    text-wrap: pretty;
    margin-top: 20px;
    margin-bottom: 0;
    color: var(--text-secondary);
    animation: heroBlurIn 0.8s var(--ease-out) 0.45s both;
  }

  /* Meta bar */
  .article-hero__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    animation: heroBlurIn 0.8s var(--ease-out) 0.55s both;
  }

  .article-hero__meta-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 500;
  }

  .article-hero__meta-item svg {
    flex-shrink: 0;
    opacity: 0.5;
  }

  .article-hero__meta-divider {
    width: 1px;
    height: 16px;
    background: var(--border);
  }

  /* Copy link */
  .article-hero__copy-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-tertiary);
    padding: 2px 6px;
    margin: -2px -6px;
    transition:
      color var(--duration-fast) var(--ease-smooth),
      background var(--duration-fast) var(--ease-smooth);
  }

  .article-hero__copy-link svg {
    flex-shrink: 0;
    opacity: 0.5;
  }

  .article-hero__copy-link:hover {
    color: var(--accent);
    background: var(--accent-light);
  }

  .article-hero__copy-link:hover svg {
    opacity: 0.8;
  }

  .article-hero__copy-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    background: var(--accent-light);
  }

  .article-hero__copy-link--copied {
    color: var(--green);
  }

  .article-hero__copy-link--copied svg {
    opacity: 0.8;
  }

  /* heroBlurIn keyframes defined globally in global.css */

  /* Responsive */
  @media (max-width: 600px) {
    .article-hero__meta {
      gap: 8px;
    }
    .article-hero__meta-divider {
      display: none;
    }
    .article-hero__tags {
      gap: 5px;
    }
    :global(.article-hero__tag) {
      font-size: 11px;
      padding: 8px 14px;
      min-height: 44px;
    }
  }
</style>
