---
/**
 * "Behind the Catalog" section — paper card with citation block
 * (APA/BibTeX/Markdown) and author identity. Relies on shared
 * section styles from about.astro.
 */
import {
  CITATION,
  SPRINGER_PAPER_URL,
  SPRINGER_DOI,
  AUTHOR_PROFILE_URL,
  GITHUB_PROFILE_URL,
  PERSONAL_WEBSITE_URL,
  GITHUB_REPO,
  GITHUB_ISSUES_URL,
  ACADEMIC_CITATIONS_FALLBACK,
  THESIS_URL,
} from '../../lib/constants';
import Icon from '../icons/Icon.astro';
import {
  ICON_BOOK_LINES,
  ICON_USER,
  ICON_CALENDAR,
  ICON_EXTERNAL_LINK,
  ICON_COPY,
  ICON_STAR,
  ICON_GRADUATION_CAP,
  ICON_TAG,
  ICON_CLOCK,
  ICON_GITHUB,
  ICON_GLOBE,
  ICON_LINKEDIN,
} from '../../lib/icon-paths';

interface Props {
  smellCount: number;
}

const { smellCount } = Astro.props;

const markdownCitation = `[Code Smells: A Comprehensive Online Catalog and Taxonomy](${SPRINGER_PAPER_URL}) — *Studies in Systems, Decision and Control, vol 462.* Springer, 2023.`;

const FETCH_TIMEOUT_MS = 5_000;

const [starsResult, citationsResult] = await Promise.allSettled([
  fetch(`https://api.github.com/repos/${GITHUB_REPO}`, {
    headers: { Accept: 'application/vnd.github.v3+json' },
    signal: AbortSignal.timeout(FETCH_TIMEOUT_MS),
  }).then((r) => (r.ok ? r.json() : null)),

  fetch(`https://api.semanticscholar.org/graph/v1/paper/DOI:${SPRINGER_DOI}?fields=citationCount`, {
    signal: AbortSignal.timeout(FETCH_TIMEOUT_MS),
  }).then((r) => (r.ok ? r.json() : null)),
]);

const githubStars =
  starsResult.status === 'fulfilled' && starsResult.value?.stargazers_count
    ? Number(starsResult.value.stargazers_count)
    : 0;

const academicCitations =
  citationsResult.status === 'fulfilled' && citationsResult.value?.citationCount != null
    ? Number(citationsResult.value.citationCount)
    : ACADEMIC_CITATIONS_FALLBACK;
---

<div class="about-section section-wide" id="sec-research">
  <div class="section-label">Behind the Catalog</div>
  <h2>The Research &amp; the Author</h2>
  <p>
    This whole thing started because I couldn&rsquo;t find a single place that collected all the
    smells. So I spent the better part of a year reading the papers, and published the taxonomy
    through Springer Nature. If it&rsquo;s been useful, the citation goes a long way.
  </p>

  <!-- ===== ACT 1: THE RESEARCH ===== -->
  <div class="paper-card" id="researchCard">
    <div class="paper-visual">
      <div class="paper-visual-icon">
        <Icon icon={ICON_BOOK_LINES} size={32} strokeWidth={1.5} />
      </div>
      <div class="paper-visual-label">Springer</div>
    </div>
    <div class="paper-info">
      <h3>
        <a href={SPRINGER_PAPER_URL} class="paper-title-link" target="_blank" rel="noopener"
          >Code Smells: A Comprehensive Online Catalog and Taxonomy</a
        >
      </h3>
      <div class="paper-meta">
        <span>
          <Icon icon={ICON_USER} size={12} />
          Marcel Jerzyk, Lech Madeyski
        </span>
        <span>
          <Icon icon={ICON_CALENDAR} size={12} />
          2023
        </span>
        <span>
          <Icon icon={ICON_BOOK_LINES} size={12} />
          Springer Nature &middot; Studies in Systems, vol 462
        </span>
      </div>
      <p class="paper-desc">
        What happens when you read 40+ papers about code smells and organize everything into one
        place? {smellCount} named smells across 5 taxonomy dimensions&thinsp;&mdash;&thinsp;with every
        causal relationship mapped.
      </p>
      <div class="paper-actions">
        <a href={SPRINGER_PAPER_URL} class="cta-button" target="_blank" rel="noopener">
          <Icon icon={ICON_EXTERNAL_LINK} size={14} />
          Read the Paper
        </a>
        <a href={THESIS_URL} class="ghost-button" target="_blank" rel="noopener">
          <Icon icon={ICON_BOOK_LINES} size={14} />
          Read the Thesis
        </a>
      </div>

      <!-- Citation block -->
      <div
        class="cite-block"
        id="rcCiteBlock"
        data-apa={CITATION.apaText}
        data-bibtex={CITATION.bibtex}
        data-markdown={markdownCitation}
      >
        <div class="cite-sweep" id="rcCiteSweep"></div>
        <div class="cite-header">
          <span class="cite-label">Citation</span>
          <div class="cite-tabs">
            <button class="cite-tab active" data-fmt="apa">APA</button>
            <button class="cite-tab" data-fmt="bibtex">BibTeX</button>
            <button class="cite-tab" data-fmt="markdown">Markdown</button>
          </div>
        </div>
        <pre class="cite-text" id="rcCiteText">{CITATION.apaText}</pre>
        <button class="cite-copy" id="rcCiteCopy" aria-label="Copy citation">
          <Icon icon={ICON_COPY} size={12} />
          <span id="rcCiteCopyLabel">Copy</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Research impact strip -->
  <div class="research-stats" id="researchStats">
    {
      githubStars > 0 && (
        <div class="research-stat">
          <div class="research-stat-icon">
            <Icon icon={ICON_STAR} size={16} />
          </div>
          <div class="research-stat-num" data-target={String(githubStars)}>
            {githubStars}
          </div>
          <div class="research-stat-label">GitHub stars</div>
        </div>
      )
    }
    <div class="research-stat">
      <div class="research-stat-icon">
        <Icon icon={ICON_GRADUATION_CAP} size={16} />
      </div>
      <div class="research-stat-num" data-target={String(academicCitations)}>
        {academicCitations}
      </div>
      <div class="research-stat-label">Academic citations</div>
    </div>
    <div class="research-stat">
      <div class="research-stat-icon">
        <Icon icon={ICON_TAG} size={16} />
      </div>
      <div class="research-stat-num" data-target={String(smellCount)}>{smellCount}</div>
      <div class="research-stat-label">Smells cataloged</div>
    </div>
    <div class="research-stat">
      <div class="research-stat-icon">
        <Icon icon={ICON_CLOCK} size={16} />
      </div>
      <div class="research-stat-num" data-target="40" data-suffix="+">40+</div>
      <div class="research-stat-label">Papers surveyed</div>
    </div>
  </div>

  <!-- ===== BRIDGE ===== -->
  <div class="curator-bridge" id="researchBridge">
    <div class="curator-bridge-line"></div>
    <div
      class="curator-bridge-monogram"
      title="The M stands for Marcel. The J stands for Jerzyk. The obsession stands for itself."
    >
      MJ
    </div>
    <div class="curator-bridge-line"></div>
  </div>
  <p class="curator-bridge-text" id="bridgeText">
    Papers don&rsquo;t write themselves. Catalogs don&rsquo;t either.
  </p>

  <!-- ===== ACT 2: THE RESEARCHER ===== -->
  <div class="curator-voice" id="researcherZone">
    <!-- Identity -->
    <div class="curator-identity" id="curatorIdentity">
      <div class="curator-photo-wrap" id="curatorPhoto">
        <img
          src="/images/marcel-jerzyk.png"
          alt="Marcel Jerzyk"
          class="curator-photo"
          width="96"
          height="96"
          loading="lazy"
        />
      </div>
      <div class="curator-name-block">
        <h3 class="curator-name">Marcel Jerzyk</h3>
        <div class="curator-role">
          Senior Software Engineer <span class="curator-amp">&amp;</span> Smell Taxonomist
        </div>
        <div class="curator-provenance">
          Springer Nature, 2023<span class="curator-prov-sep">&middot;</span>Wroc&#322;aw University
          of Science and Technology
        </div>
      </div>
    </div>

    <!-- Pull quote -->
    <div class="curator-thesis" id="curatorThesis">
      <p>
        I read 40 papers about code smells so you don&rsquo;t have to. Then I built this catalog
        because the research deserved better than a PDF nobody opens.
      </p>
    </div>

    <p class="curator-grounding">
      Engineer, researcher, music producer. Pattern recognition is the thread.
    </p>

    <!-- Social links -->
    <div class="curator-links" id="curatorLinks">
      <a href={GITHUB_PROFILE_URL} class="curator-link" target="_blank" rel="me noopener">
        <Icon icon={ICON_GITHUB} size={14} />
        GitHub
      </a>
      <a href={PERSONAL_WEBSITE_URL} class="curator-link" target="_blank" rel="me noopener">
        <Icon icon={ICON_GLOBE} size={14} />
        Website
      </a>
      <a href={AUTHOR_PROFILE_URL} class="curator-link" target="_blank" rel="me noopener">
        <Icon icon={ICON_LINKEDIN} size={14} />
        LinkedIn
      </a>
    </div>

    <p class="curator-reach-out">
      Questions about the taxonomy?
      <a href={GITHUB_ISSUES_URL} target="_blank" rel="noopener">Open an issue</a> or
      <a href={AUTHOR_PROFILE_URL} target="_blank" rel="noopener">say&thinsp;hi</a>.
    </p>

    <!-- Sign-off -->
    <div class="curator-signoff" id="curatorSignoff">
      <a href="/" class="curator-signoff-link">
        Enough backstory&thinsp;&mdash;&thinsp;the code isn&rsquo;t going to review itself.&ensp;<span
          class="curator-signoff-arrow">&rarr;</span
        >
      </a>
    </div>
  </div>
</div>

<script>
  import { initOnce } from '../../lib/lifecycle';
  import { animateCountUp } from '../../lib/count-up';
  import { copyToClipboardWithFeedback, COPY_FEEDBACK_MS } from '../../lib/copy-code';
  import { staggerReveal } from '../../lib/observe-reveal';

  initOnce('#sec-research', (root) => {
    function getById<T extends HTMLElement>(id: string): T | null {
      return root.querySelector<T>(`#${id}`);
    }

    const research = {
      card: getById<HTMLElement>('researchCard'),
      stats: getById<HTMLElement>('researchStats'),
    };

    if (!research.card || !research.stats) return;
    const researchCard = research.card;
    const researchStats = research.stats;

    const curator = {
      bridge: getById<HTMLElement>('researchBridge'),
      bridgeText: getById<HTMLElement>('bridgeText'),
      zone: getById<HTMLElement>('researcherZone'),
      identity: getById<HTMLElement>('curatorIdentity'),
      photo: getById<HTMLElement>('curatorPhoto'),
      thesis: getById<HTMLElement>('curatorThesis'),
      links: getById<HTMLElement>('curatorLinks'),
      signoff: getById<HTMLElement>('curatorSignoff'),
    };

    const cleanupResearchReveal = staggerReveal(
      researchCard,
      [
        { el: researchCard },
        {
          el: researchStats,
          delayMs: 500,
          onReveal: () => animateCountUp(researchStats),
        },
      ],
      { threshold: 0.2 },
    );

    const cleanupCuratorReveal =
      curator.bridge &&
      curator.bridgeText &&
      curator.zone &&
      curator.identity &&
      curator.photo &&
      curator.thesis &&
      curator.links &&
      curator.signoff
        ? staggerReveal(
            curator.bridge,
            [
              { el: curator.bridge },
              { el: curator.bridgeText },
              { el: curator.zone, delayMs: 200 },
              { el: curator.identity, delayMs: 350 },
              { el: curator.photo, delayMs: 450 },
              { el: curator.thesis, delayMs: 550 },
              { el: curator.links, delayMs: 650 },
              { el: curator.links, delayMs: 1100, className: 'ready' },
              { el: curator.signoff, delayMs: 750 },
            ],
            { threshold: 0.15 },
          )
        : () => {};

    /* ── Citation format toggle + copy ── */
    const citeBlock = getById<HTMLElement>('rcCiteBlock');
    const citeText = getById<HTMLElement>('rcCiteText');
    const citeCopy = getById<HTMLButtonElement>('rcCiteCopy');
    const citeCopyLabel = getById<HTMLElement>('rcCiteCopyLabel');
    const citeSweep = getById<HTMLElement>('rcCiteSweep');

    if (citeBlock && citeText) {
      const tabs = citeBlock.querySelectorAll<HTMLButtonElement>('.cite-tab');

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          tabs.forEach((t) => t.classList.remove('active'));
          tab.classList.add('active');
          const fmt = tab.dataset.fmt ?? 'apa';
          citeText.textContent = citeBlock.getAttribute(`data-${fmt}`) ?? '';
        });
      });

      citeCopy?.addEventListener('click', async () => {
        const text = citeText.textContent ?? '';
        if (
          !(await copyToClipboardWithFeedback(text, citeCopy, { durationMs: COPY_FEEDBACK_MS }))
        ) {
          return;
        }

        if (citeCopyLabel) citeCopyLabel.textContent = 'Copied!';
        citeSweep?.classList.add('sweeping');
        setTimeout(() => citeSweep?.classList.remove('sweeping'), 500);
        setTimeout(() => {
          if (citeCopyLabel) citeCopyLabel.textContent = 'Copy';
        }, COPY_FEEDBACK_MS);
      });
    }

    return () => {
      cleanupResearchReveal();
      cleanupCuratorReveal();
    };
  });
</script>

<style>
  /* ============================================
     PAPER CARD
     ============================================ */
  .paper-card {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(20px, 3vw, 32px);
    align-items: start;
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: clamp(24px, 3vw, 36px);
    margin-top: 28px;
    box-shadow: var(--shadow-md);
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.5s var(--ease-out),
      transform 0.5s var(--ease-out),
      box-shadow 0.3s;
  }

  .paper-card.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  @media (hover: hover) {
    .paper-card.revealed:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }
  }

  .paper-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(to bottom, var(--accent), var(--purple));
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.6s var(--ease-out);
  }

  .paper-card.revealed::before {
    transform: scaleY(1);
    transition-delay: 0.2s;
  }

  /* Springer visual thumbnail */
  .paper-visual {
    width: 96px;
    height: 128px;
    background: linear-gradient(
      145deg,
      var(--accent-light) 0%,
      color-mix(in srgb, var(--purple-light) 50%, var(--accent-light)) 100%
    );
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s var(--ease-spring);
  }

  @media (hover: hover) {
    .paper-visual:hover {
      transform: perspective(400px) rotateY(-4deg);
    }
  }

  .paper-visual::before {
    content: '';
    position: absolute;
    inset: -6px;
    border: 2px solid var(--accent);
    border-radius: 50%;
    opacity: 0;
    transform: rotate(-12deg) scale(0.85);
    transition:
      opacity 0.4s var(--ease-out),
      transform 0.4s var(--ease-spring);
  }

  .paper-card.revealed .paper-visual::before {
    opacity: 0.07;
    transform: rotate(-5deg) scale(1);
    transition-delay: 0.3s;
  }

  .paper-visual::after {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .paper-visual-icon {
    color: var(--accent);
    opacity: 0.5;
  }

  .paper-visual-label {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    opacity: 0.6;
  }

  /* Paper info */
  .paper-info h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    font-variation-settings: 'opsz' 32;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .paper-title-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  @media (hover: hover) {
    .paper-title-link:hover {
      color: var(--accent);
    }
  }

  .paper-meta {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-bottom: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 16px;
  }

  .paper-meta span {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .paper-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 18px;
    max-width: none;
  }

  .paper-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ============================================
     CITATION BLOCK
     ============================================ */
  .cite-block {
    margin-top: 20px;
    background: var(--surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 16px 20px;
    position: relative;
    overflow: hidden;
  }

  .cite-sweep {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--accent-light) 40%,
      var(--accent-light) 60%,
      transparent 100%
    );
    opacity: 0;
    transform: translateX(-100%);
    pointer-events: none;
    z-index: 1;
  }

  .cite-sweep.sweeping {
    opacity: 0.6;
    animation: rcCiteSweep 0.4s var(--ease-out) forwards;
  }

  @keyframes rcCiteSweep {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(100%);
    }
  }

  .cite-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .cite-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }

  .cite-tabs {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .cite-tab {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 4px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .cite-tab.active {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-light);
  }

  .cite-tab:not(.active):hover {
    color: var(--text-secondary);
    background: var(--surface-hover);
  }

  .cite-text {
    font-family: var(--font-mono);
    font-size: clamp(11px, 1vw + 6px, 12.5px);
    color: var(--text-secondary);
    line-height: 1.7;
    word-break: break-word;
    white-space: pre-wrap;
    margin: 0;
    background: transparent;
    padding: 0;
    border: none;
    overflow: visible;
  }

  .cite-copy {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 4px 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all 0.2s var(--ease-spring);
  }

  @media (hover: hover) {
    .cite-copy:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-light);
    }
  }

  .cite-copy.copied {
    background: var(--green-light);
    border-color: var(--green);
    color: var(--green);
    animation: rcCopySquish 0.3s var(--ease-spring);
  }

  @keyframes rcCopySquish {
    0% {
      transform: scale(1);
    }
    40% {
      transform: scale(0.88);
    }
    100% {
      transform: scale(1);
    }
  }

  /* ============================================
     RESEARCH STATS STRIP
     ============================================ */
  .research-stats {
    display: flex;
    justify-content: center;
    gap: 0;
    margin-top: 20px;
    background: var(--surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.4s var(--ease-out);
  }

  .research-stats.revealed {
    opacity: 1;
  }

  .research-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 16px 12px;
    min-width: 0;
  }

  .research-stat + .research-stat {
    border-left: 1px solid var(--border-subtle);
  }

  .research-stat-icon {
    color: var(--text-tertiary);
    opacity: 0.6;
    margin-bottom: 2px;
  }

  .research-stat-num {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    font-variation-settings: 'opsz' 32;
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .research-stat-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    text-align: center;
  }

  /* ============================================
     CURATOR BRIDGE
     ============================================ */
  .curator-bridge {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: clamp(32px, 4vw, 48px) auto 0;
    max-width: 520px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.4s var(--ease-out),
      transform 0.4s var(--ease-out);
  }

  .curator-bridge.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .curator-bridge-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
    transform: scaleX(0);
    transition: transform 0.3s var(--ease-out);
  }

  .curator-bridge-line:first-child {
    transform-origin: right;
  }

  .curator-bridge-line:last-child {
    transform-origin: left;
  }

  .curator-bridge.revealed .curator-bridge-line {
    transform: scaleX(1);
    transition-delay: 0.15s;
  }

  .curator-bridge.revealed .curator-bridge-monogram {
