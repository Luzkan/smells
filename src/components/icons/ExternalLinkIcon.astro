---
interface Props {
  size: number;
  class: string;
}

const { size, class: className } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2.5"
  stroke-linecap="round"
  aria-hidden="true"
>
  <path d="M7 17L17 7"></path>
  <path d="M7 7h10v10"></path>
</svg>
