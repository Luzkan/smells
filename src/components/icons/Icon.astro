---
/**
 * Generic icon component — renders an IconDef as an <svg>.
 *
 * Since this component has no <style>, Astro won't add scope attributes
 * to the rendered SVG. Parent components that need to style the SVG
 * (e.g. `.parent svg { ... }`) should use `:global()` for the SVG
 * descendant selector: `.parent :global(svg) { ... }`.
 */
import type { IconDef } from '../../lib/icon-paths';

interface Props {
  icon: IconDef;
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { icon, size = 14, class: className, strokeWidth = 2 } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox={icon.viewBox ?? '0 0 24 24'}
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  {...icon.strokeLinejoin ? { 'stroke-linejoin': 'round' } : {}}
  aria-hidden="true"
  set:html={icon.body}
/>
